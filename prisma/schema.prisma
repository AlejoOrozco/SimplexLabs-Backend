/// *
/// * Dedicated dedupe choke-point for every inbound provider event.
/// *
/// * The insert uses a unique constraint on `(provider, providerEventId)`.
/// * The webhook services MUST attempt the insert BEFORE any side-effect:
/// *   - First delivery  → row created, `status = PROCESSED` after work.
/// *   - Retry delivery  → unique conflict (P2002) → webhook handler returns
/// *     immediately, guaranteeing zero duplicate writes downstream.
/// *
/// * We deliberately keep this table narrow: no payload, no metadata. The
/// * business rows (Message / PaymentEvent) remain the source of truth; this
/// * table exists solely so `IF EXISTS` checks are race-free.
model WebhookEvent {
  id              String             @id @default(uuid())
  /// e.g. "meta:whatsapp", "meta:instagram", "stripe"
  provider        String             @map("provider")
  /// Provider-assigned event id. For Meta inbound messages: wamid / wa_id.
  /// For Stripe: `evt_...`. Never the internal row id.
  providerEventId String             @map("provider_event_id")
  /// Company scope where discoverable. Null for Stripe until reconciled.
  companyId       String?            @map("company_id")
  status          WebhookEventStatus @default(RECEIVED) @map("status")
  /// Short classification after terminal processing (e.g. "confirmed",
  /// "duplicate", "ignored_event_type:...").
  outcome         String?            @map("outcome")
  firstSeenAt     DateTime           @default(now()) @map("first_seen_at")
  processedAt     DateTime?          @map("processed_at")

  @@unique([provider, providerEventId])
  @@index([companyId, firstSeenAt])
  @@map("webhook_events")
}

/// *
/// * Dead-letter capture for any async work that has exhausted its retry
/// * budget or hit a non-retryable terminal error. Operators replay these
/// * rows via an admin endpoint; each replay inserts a new audit line on
/// * the downstream table (AgentRun, NotificationDelivery, etc.) so the
/// * replay itself is traceable.
model FailedTask {
  id           String           @id @default(uuid())
  companyId    String?          @map("company_id")
  /// Opaque discriminator — controls how the replay endpoint dispatches.
  /// Values: "pipeline.run", "notification.delivery", "meta.send".
  taskType     String           @map("task_type")
  /// Fully-serialized input (JSON). Must not contain secrets; the
  /// producer is responsible for redaction before handoff.
  payload      Json             @map("payload")
  /// Last recorded error message (<=2k chars). Never a stack trace.
  lastError    String           @map("last_error")
  attempts     Int              @default(1) @map("attempts")
  status       FailedTaskStatus @default(PENDING_REPLAY) @map("status")
  /// When status=REPLAYED, the id of the downstream row that superseded it.
  replacedById String?          @map("replaced_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([companyId, taskType])
  @@map("failed_tasks")
}

model NotificationDelivery {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  channel        NotificationChannel @map("channel")
  /// Destination identifier (email address, phone number, or user id for IN_APP).
  destination    String              @map("destination")
  /// null = pending; set once a provider has accepted the send.
  sentAt         DateTime?           @map("sent_at")
  failedAt       DateTime?           @map("failed_at")
  errorMessage   String?             @map("error_message")
  providerRefId  String?             @map("provider_ref_id")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  notification   Notification        @relation("NotificationDeliveries", fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_deliveries")
}

model CompanySettings {
  id                         String   @id @default(uuid())
  companyId                  String   @unique @map("company_id")
  /// IANA timezone, e.g. "America/Mexico_City". Used for scheduling math.
  timezone                   String   @default("America/Mexico_City") @map("timezone")
  defaultSlotDurationMinutes Int      @default(30) @map("default_slot_duration_minutes")
  /// After this many hours of inactivity, the agent may auto-close the conversation.
  inactivityCloseHours       Int      @default(48) @map("inactivity_close_hours")
  stripeEnabled              Boolean  @default(false) @map("stripe_enabled")
  wireTransferEnabled        Boolean  @default(false) @map("wire_transfer_enabled")
  wireTransferInstructions   String?  @map("wire_transfer_instructions")
  notificationEmail          String?  @map("notification_email")
  notificationWhatsapp       String?  @map("notification_whatsapp")
  inAppNotificationsEnabled  Boolean  @default(true) @map("in_app_notifications_enabled")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  company                    Company  @relation("CompanySettings", fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

